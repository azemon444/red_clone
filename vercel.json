{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "patched-app/assets/**,mock-server/public/**,mock-server/data/**"
    }
  },
  "crons": [
    { "path": "/health", "schedule": "0 12 * * *" }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ]
}
